# Wave Server Configuration
# Copy to .env and fill in your values.
# All variables use the WAVE_ prefix.

# GitHub PAT (fine-grained) — Contents + Pull Requests read/write
# Fallback if GitHub Apps are not configured.
# WAVE_GITHUB_TOKEN=github_pat_xxxx

# GitHub App: coding bot — pushes branches, creates PRs into target branch
# WAVE_GITHUB_CODING_APP_ID=
# WAVE_GITHUB_CODING_APP_KEY=~/.config/pi-legion/coding-bot.pem  # or inline PEM
# WAVE_GITHUB_CODING_APP_INSTALL_ID=

# GitHub App: review bot — approves/merges PRs, creates promotion PRs
# WAVE_GITHUB_REVIEW_APP_ID=
# WAVE_GITHUB_REVIEW_APP_KEY=~/.config/pi-legion/review-bot.pem  # or inline PEM
# WAVE_GITHUB_REVIEW_APP_INSTALL_ID=

# Default target branch for coding-bot PRs (e.g. "dev" instead of source branch)
# WAVE_GITHUB_PR_TARGET=dev

# Agent commit signing — GPG key ID or SSH key path
# WAVE_GIT_COMMITTER_NAME=wave-bot
# WAVE_GIT_COMMITTER_EMAIL=wave-bot@example.com
# WAVE_GIT_SIGNING_KEY=~/.ssh/wave_ed25519

# Concurrency and timeouts
# WAVE_DEFAULT_CONCURRENCY=4
# WAVE_DEFAULT_TIMEOUT_MS=300000

# Database (defaults to SQLite in ./data/)
# WAVE_DATABASE_URL=sqlite+aiosqlite:///./data/wave-server.db
