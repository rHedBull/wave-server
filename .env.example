# Wave Server Configuration
# Copy to .env and fill in your values.
# All variables use the WAVE_ prefix.

# GitHub PAT (fine-grained) — Contents + Pull Requests read/write
# WAVE_GITHUB_TOKEN=github_pat_xxxx

# Agent commit signing — GPG key ID or SSH key path
# WAVE_GIT_COMMITTER_NAME=wave-bot
# WAVE_GIT_COMMITTER_EMAIL=wave-bot@example.com
# WAVE_GIT_SIGNING_KEY=~/.ssh/wave_ed25519

# Concurrency and timeouts
# WAVE_DEFAULT_CONCURRENCY=4
# WAVE_DEFAULT_TIMEOUT_MS=300000

# Database (defaults to SQLite in ./data/)
# WAVE_DATABASE_URL=sqlite+aiosqlite:///./data/wave-server.db
